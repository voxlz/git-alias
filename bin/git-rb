#!/usr/bin/env bash
# git-rb: Fetch and interactive rebase onto origin's default branch with autosquash
# Usage: git rb
git fetch
default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/||') || true
if [ -z "$default_branch" ]; then
  if git rev-parse --verify origin/main >/dev/null 2>&1; then
    default_branch=origin/main
  else
    default_branch=origin/master
  fi
fi
exec git rebase "$default_branch" -i "$@"
